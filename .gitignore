# ============================================
# 敏感文件 - 绝对不能上传
# ============================================

# 环境变量文件（包含 API Key 等密钥）
.env
.env.*
!.env.example
**/.env
**/.env.local
**/.env.*.local

# 配置文件（可能包含敏感信息）
config.json
**/config.json
config.local.*
settings.local.*

# 密钥和证书
*.pem
*.key
*.crt
*.p12
*.pfx
*.jks
*.keystore
id_rsa*
id_ed25519*
*.pub

# 凭证文件
credentials*
secrets*
*.secret
*.credentials

# 数据库文件
*.sqlite
*.sqlite3
*.db
*.db3

# ============================================
# 项目特定敏感目录
# ============================================

# 会话数据（包含用户对话记录）
backend/sessions/

# 日志文件
backend/logs/
*.log
logs/

# 工作区文件（用户上传的文件）


# ============================================
# 依赖目录
# ============================================

node_modules/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
.venv/
venv/
env/
ENV/

# ============================================
# 构建输出
# ============================================

frontend/.next/
frontend/out/
frontend/dist/
build/
dist/
*.egg-info/
.eggs/

# ============================================
# IDE 和编辑器
# ============================================

.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-*

# ============================================
# 操作系统文件
# ============================================

.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ============================================
# TypeScript
# ============================================

*.tsbuildinfo

# ============================================
# 测试覆盖率
# ============================================

coverage/
.coverage
htmlcov/
.pytest_cache/
.nyc_output/

# ============================================
# 其他
# ============================================

*.bak
*.tmp
*.temp
.cache/
